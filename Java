public class KalolCity {
    private String name = "Kalol";
    private String district = "Gandhinagar";
    private String landmark = "IFFCO Fertilizer Plant";

    public void displayProfile() {
        System.out.println("City Identity Profile");
        System.out.println("---------------------");
        System.out.println("Name:     " + name);
        System.out.println("District: " + district);
        System.out.println("Landmark: " + landmark);
        System.out.println("Connectivity: Main Railway Junction (Ahmedabad-Mehsana line)");
    }

    public static void main(String[] args) {
        new KalolCity().displayProfile();
    }
}
