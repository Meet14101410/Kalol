<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Kalol Profile - Industrial Hub</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; display: flex; justify-content: center; padding: 20px; }
        .dashboard { background: white; width: 500px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); border-top: 6px solid #27ae60; overflow: hidden; }
        header { background: #f8f9fa; padding: 20px; text-align: center; border-bottom: 1px solid #eee; }
        .stats { padding: 20px; }
        .stat-box { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px dashed #ddd; }
        .label { font-weight: bold; color: #2c3e50; }
        .value { color: #27ae60; }
    </style>
</head>
<body>
    <div class="dashboard">
        <header>
            <h1>🏢 Kalol</h1>
            <p>Gandhinagar, Gujarat</p>
        </header>
        <div class="stats">
            <div class="stat-box"><span class="label">District:</span><span class="value">Gandhinagar</span></div>
            <div class="stat-box"><span class="label">Major Industry:</span><span class="value">IFFCO Fertilizer</span></div>
            <div class="stat-box"><span class="label">Admin Status:</span><span class="value">Taluka Headquarters</span></div>
            <div class="stat-box"><span class="label">Pincode:</span><span class="value">382721</span></div>
        </div>
    </div>
</body>
</html>
